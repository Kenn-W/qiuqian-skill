  "najia": {
    "description": "纳甲：八宫配天干，每爻配地支",
    "palace_stems": {
      "乾": {"stem": "甲", "inner_stem": "甲", "outer_stem": "壬"},
      "兑": {"stem": "丁"},
      "离": {"stem": "己"},
      "震": {"stem": "庚"},
      "巽": {"stem": "辛"},
      "坎": {"stem": "戊"},
      "艮": {"stem": "丙"},
      "坤": {"stem": "乙", "inner_stem": "乙", "outer_stem": "癸"}
    },
    "line_branches": {
      "note": "地支从初爻到上爻，按阳卦顺行/阴卦逆行，隔位而取",
      "阳卦顺行": "乾子寅辰午申戌, 坎寅辰午申戌子, 艮辰午申戌子寅, 震子寅辰午申戌",
      "阴卦逆行": "坤未巳卯丑亥酉, 巽丑亥酉未巳卯, 离卯丑亥酉未巳, 兑巳卯丑亥酉未",
      "details": {
        "乾": ["子", "寅", "辰", "午", "申", "戌"],
        "坎": ["寅", "辰", "午", "申", "戌", "子"],
        "艮": ["辰", "午", "申", "戌", "子", "寅"],
        "震": ["子", "寅", "辰", "午", "申", "戌"],
        "坤": ["未", "巳", "卯", "丑", "亥", "酉"],
        "巽": ["丑", "亥", "酉", "未", "巳", "卯"],
        "离": ["卯", "丑", "亥", "酉", "未", "巳"],
        "兑": ["巳", "卯", "丑", "亥", "酉", "未"]
      }
    }
  },

  "liuqin": {
    "description": "六亲定法：卦宫五行 vs 爻地支五行",
    "five_elements": ["木", "火", "土", "金", "水"],
    "rules": {
      "生我者为父母": "宫生爻 → 父母",
      "我生者为子孙": "爻生宫 → 子孙",
      "克我者为官鬼": "爻克宫 → 官鬼",
      "我克者为妻财": "宫克爻 → 妻财",
      "比和者为兄弟": "宫爻同五行 → 兄弟"
    },
    "di-zhi-wuxing": {
      "寅": "木", "卯": "木",
      "巳": "火", "午": "火",
      "辰": "土", "戌": "土", "丑": "土", "未": "土",
      "申": "金", "酉": "金",
      "亥": "水", "子": "水"
    }
  },

  "liushou": {
    "description": "六兽（六神）：按占卦日干顺排，从初爻到上爻",
    "order": ["青龙", "朱雀", "勾陈", "螣蛇", "白虎", "玄武"],
    "day_start": {
      "甲乙日": "青龙起",
      "丙丁日": "朱雀起",
      "戊日": "勾陈起",
      "己日": "螣蛇起",
      "庚辛日": "白虎起",
      "壬癸日": "玄武起"
    }
  },

  "yongshen": {
    "description": "用神取法：按所问之事取对应六亲为用神",
    "mapping": {
      "事业/功名/考试": "官鬼",
      "财运/生意/投资": "妻财",
      "感情/婚姻/恋爱": "妻财（男问）或官鬼（女问），兼看应爻",
      "健康/疾病": "世爻 + 子孙（医药）",
      "人际关系/合作": "兄弟 + 应爻",
      "出行/远行": "世爻 + 应爻",
      "父母/长辈/文书": "父母",
      "子女/晚辈/宠物": "子孙",
      "房产/车辆/财物": "父母（不动产）或妻财（动产）"
    }
  },

  "wang-shuai": {
    "description": "旺衰判断：月建日辰对爻支的生克冲合决定旺度",
    "levels": {
      "旺": "得月建日辰生扶，当令而旺",
      "相": "得月建日辰之气，次旺",
      "休": "生月建日辰，泄气",
      "囚": "克月建日辰，被困",
      "死": "被月建日辰所克，衰弱"
    }
  }
